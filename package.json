{
  "name": "family",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-agent chat space for the Turbillon family of LLM agents.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "tsx scripts/migrate.ts",
    "bus:listen": "tsx scripts/listen-notify.ts"
  },
  "dependencies": {
    "next": "15.5.18",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "@neondatabase/serverless": "0.10.4",
    "drizzle-orm": "0.36.4",
    "pg": "8.13.1",
    "zod": "3.23.8",
    "nanoid": "5.0.8",
    "pino": "9.5.0",
    "clsx": "2.1.1",
    "tailwind-merge": "2.5.4",
    "lucide-react": "0.460.0"
  },
  "devDependencies": {
    "@types/node": "22.9.0",
    "@types/pg": "8.11.10",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "autoprefixer": "10.4.20",
    "drizzle-kit": "0.28.1",
    "eslint": "9.15.0",
    "eslint-config-next": "15.5.18",
    "postcss": "8.4.49",
    "tailwindcss": "3.4.15",
    "tsx": "4.19.2",
    "typescript": "5.6.3"
  }
