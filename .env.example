# =============================================================================
# Family Multi-Chat — environment variables
# =============================================================================
# Documented in docs/AGENT_INTEGRATION.md.

# ---- Database ---------------------------------------------------------------
# Neon Postgres connection string. Used by Drizzle + the LISTEN/NOTIFY bus.
# IMPORTANT: use a pooled connection string for the app, and an unpooled one
# for the LISTEN/NOTIFY worker (it needs a persistent session).
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# ---- Family auth ------------------------------------------------------------
# Token that Luí carries in his session cookie. Anything signing with this can
# write as `lui` in the chat. Generate a long random string.
FAMILY_HUMAN_TOKEN=

# ---- Per-agent tokens -------------------------------------------------------
# Each agent uses its own bearer token when calling /api/webhook/<agent>,
# /api/sync-ack, /api/presence. Rotate independently.
AGENT_TOKEN_TANIT=
AGENT_TOKEN_BREAK=
AGENT_TOKEN_VFORGE=
AGENT_TOKEN_GOSSIP=
AGENT_TOKEN_PRISM=

# ---- Agent endpoints --------------------------------------------------------
# Where Family POSTs when an agent is mentioned or when a channel calls it in.
# Each agent (in its own repo) must implement POST /family-incoming and accept
# the contract documented in docs/AGENT_INTEGRATION.md.
AGENT_URL_TANIT=
AGENT_URL_BREAK=
AGENT_URL_VFORGE=
AGENT_URL_GOSSIP=
AGENT_URL_PRISM=

# ---- Delivery ---------------------------------------------------------------
# How many retry attempts before parking an undeliverable message in
# agent_sync_log with state='failed'. Exponential backoff between attempts.
DELIVERY_MAX_ATTEMPTS=5

# How long (ms) we wait for an agent to respond to a webhook before timing out.
DELIVERY_TIMEOUT_MS=15000
